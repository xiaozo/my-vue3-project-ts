# 生产环境配置
# uniapp vue3.0 生产环境变量

# 基础配置
NODE_ENV=production

# 接口地址
VITE_API_BASE_URL=https://api.example.com/api

# 微信小程序 AppID
VITE_MP_WEIXIN_APPID=your_weixin_appid

# H5 配置
VITE_H5_TITLE=uniapp vue3.0

# 其他自定义配置
VITE_CUSTOM_KEY=production_value

# 生产环境特有配置
VITE_ENABLE_MOCK=false
VITE_LOG_LEVEL=error
